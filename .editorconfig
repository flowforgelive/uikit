# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
tab_width = 2

# Kotlin files
[*.{kt,kts}]
indent_style = tab
indent_size = 2
tab_width = 2
ktlint_standard_function-naming = disabled

# Gradle files
[*.gradle]
indent_style = tab
indent_size = 2
tab_width = 2

# XML files
[*.xml]
indent_style = tab
indent_size = 2
tab_width = 2

# JSON files
[*.json]
indent_style = tab
indent_size = 2
tab_width = 2

# TypeScript / JavaScript files
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = tab
indent_size = 2
tab_width = 2

# CSS / SCSS files
[*.{css,scss,less}]
indent_style = tab
indent_size = 2
tab_width = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Properties files
[*.properties]
indent_style = tab
indent_size = 2
tab_width = 2

# TOML files (Gradle version catalogs)
[*.toml]
indent_style = tab
indent_size = 2
tab_width = 2
